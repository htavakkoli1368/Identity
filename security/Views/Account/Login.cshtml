@model LoginViewModel 
 <h1 class="text-danger">login</h1>
@if (ViewBag.ExternalLogins != null)
{
    foreach (var provider in ViewBag.ExternalLogins)
    {
        <form asp-action="ExternalLogin" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="provider" value="@provider.Name" />
            <input type="hidden" name="returnUrl" value="@ViewData["Returnurl"]" />

            <button type="submit" class="btn btn-outline-danger">
                Login with @provider.DisplayName
            </button>
        </form>
    }
}
 <div class="row">
     <div class="col-md-8">
        <form asp-controller="Account" asp-action="Login" asp-route-Returnurl="@ViewData["Returnurl"]" method="post" role="form">
            <h4>Login into your Account</h4>
            <hr />
            <div asp-validation-summary="All" class="text-danger"> </div>
            <div class="form-group">
                <label asp-for="Email" class="col-md-2"></label>
                <div class="col-md-10">
                    <input asp-for="Email" class="form-control" />
                    <span asp-validation-for="Email" class="text-bg-danger"></span>
                </div>
            </div>
            <div class="form-group">
                <label asp-for="Password" class="col-md-2"></label>
                <div class="col-md-10">
                    <input asp-for="Password" class="form-control" />
                    <span asp-validation-for="Password" class="text-bg-danger"></span>
                </div>
            </div>
            <div class="form-group">
               <div class="col-md-10">
                   <div class="custom-checkbox">
                       <label asp-for="RememberMe">
                            <input asp-for="RememberMe" />
                            @Html.DisplayNameFor(m=>m.RememberMe)
                       </label>
                   </div>
               </div>
            </div>
            <div class="form-group pt-lg-2">
                <div class="col-md-2">
                    <button type="submit" class="btn btn-success form-control">Login</button>
                </div>
            </div>
            <p>
                <a asp-action="Register">Register as a new user?</a>
            </p>
            <p>
                <a asp-action="ResetPassword">Forgot your Password?</a>
            </p>
        </form>
     </div>
 </div>
@section Scripts{
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
